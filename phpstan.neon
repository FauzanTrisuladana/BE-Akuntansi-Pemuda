includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - app
        - config
        - routes

    # Level 9 adalah yang paling ketat, Anda bisa mulai dari level 0 atau 5 dulu
    level: 7

    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        # Ignore covariant return type issues in model relations
        - '#Template type TDeclaringModel on class Illuminate\\Database\\Eloquent\\Relations\\BelongsTo is not covariant#'
        - '#Template type TDeclaringModel on class Illuminate\\Database\\Eloquent\\Relations\\HasMany is not covariant#'
        # Ignore generic type issues in model relations
        - '#Generic type Illuminate\\Database\\Eloquent\\Relations\\HasMany in PHPDoc tag @return does not specify all template types#'
        # Ignore missing return type on model relations (Laravel magic methods)
        - '#Method App\\Models\\.*::.* has no return type specified#'
        - '#Class App\\Models\\User uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory#'
        - '#Method App\\Models\\User::scopeFilter#'
        - '#Method App\\Models\\PenanggungJawab::scopeFilter#'
        - '#Method App\\Models\\PenanggungJawab::transaksi#'
        - '#Relation .transaksi. is not found in App\\Models\\PenanggungJawab#'
        # Ignore relation existence errors for Akun and RiilHistory (Larastan cache issue)
        - '#Relation .transaksi. is not found in App\\Models\\Akun#'
        - '#Relation .akun. is not found in App\\Models\\RiilHistory#'
        - '#Relation .mutasiDebit. is not found in App\\Models\\Akun#'
        - '#Relation .mutasiKredit. is not found in App\\Models\\Akun#'
        - '#Property App\\Models\\RiilHistory::\$akun#'
        - '#Relation .akunDebit. is not found in App\\Models\\MutasiRekening#'
        - '#Relation .akunKredit. is not found in App\\Models\\MutasiRekening#'
        - '#Access to an undefined property App\\Models\\MutasiRekening#'
        - '#Method App\\Models\\MutasiRekening::akunDebit#'
        - '#Method App\\Models\\MutasiRekening::akunKredit#'
        # Ignore variadic string parameter type issue in RoleMiddleware
        - '#Parameter \$roles of method App\\Http\\Middleware\\RoleMiddleware#'
